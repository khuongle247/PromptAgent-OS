  "complexity_issues": [
    {
      "issue": "Duplicate State Management",
      "severity": "MEDIUM",
      "affected_modules": [
        "state-manager.js (primary)",
        "global-state-engine.js (snapshots)",
        "state-recovery-engine.js (recovery)"
      ],
      "description": "Three separate modules manage state with overlapping responsibilities",
      "recommendation": "Consolidate into single state management system with optional snapshot/recovery layers",
      "impact": "If changed, must coordinate updates across three modules"
    },
    {
      "issue": "Multiple Health Check Systems",
      "severity": "LOW",
      "affected_modules": [
        "framework-health.js (reads metrics/audit)",
        "unified-validation-pipeline.js (validates files)",
        "metrics-engine.js (tracks metrics)"
      ],
      "description": "Three separate health/validation paths running in parallel",
      "recommendation": "Could consolidate validation into single pipeline with separate observability",
      "impact": "Inconsistent health signals possible if systems disagree"
    },
    {
      "issue": "Event Bus Observability Coupling",
      "severity": "MEDIUM",
      "affected_modules": [
        "event-bus.js (core)",
        "audit-engine.js (subscriber)",
