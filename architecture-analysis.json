  "evolution_graph": {
    "system_overview": "Prompt Self-Improving System - Evolution Cycle orchestrated by scheduler based on health/metrics",
    "components": [
      {
        "module": "prompt-evolution-engine.js",
        "purpose": "Orchestrates evolution cycle: analyze → improve → store → promote",
        "inputs": [
          "Current prompts (from prompt-version-manager)",
          "Audit logs (analyzed via prompt-analyzer)"
        ],
        "outputs": [
          "Improved prompt candidates (stored via prompt-version-manager)",
          "Evolution reports"
        ],
        "promotion_rules": ["successRate increase > 10%", "retryRate decreases", "ratings improve"],
        "safety": "Never auto-replaces broken prompts; requires manual review flag unless all rules pass"
      },
      {
        "module": "prompt-analyzer.js",
        "purpose": "Analyzes audit logs to detect prompt weaknesses",
        "inputs": ["logs/audit.jsonl (from AuditEngine)"],
        "outputs": [
          "Weakness reports: common-errors, retry-hotspots, phantom-patterns, missing-artifacts, healing-dependencies"
        ],
        "analysis_methods": [
          "detectCommonErrors() - identifies error patterns",
          "detectRetryHotspots() - finds tasks needing more clarity",
          "detectPhantomPatterns() - finds reported but unexecuted steps",
          "detectMissingArtifactPatterns() - finds incomplete outputs",
          "detectHealingDependency() - finds patterns requiring healing"
        ]
      },
      {
        "module": "prompt-version-manager.js",
        "purpose": "Manages prompt version lifecycle and active versions",
        "functions": [
          "getActiveVersion(role) - returns active prompt content",
          "createCandidate(role, content) - creates new candidate version",
          "promoteVersion(role, version) - makes version active",
          "listVersions(role) - lists all versions for a role",
          "getAllActiveVersions() - returns all active prompts"
        ],
        "storage": "prompts/{role}/versions.json + prompts/{role}/v{N}.md files",
        "versioning_strategy": "Semantic: active, candidate, archived"
      },
      {
        "module": "prompt-experiment-engine.js",
        "purpose": "A/B test prompt versions to validate improvements",
        "functions": [
          "createExperiment(role, versionA, versionB) - creates test",
          "recordExecution(experimentId, version, result) - records outcome",
          "compareVersions(experimentId) - computes stats",
          "getWinner(experimentId) - identifies better version"
        ],
        "integration": "Optional - can validate evolution before promotion"
      },
      {
        "module": "prompt-evolution-scheduler.js",
        "purpose": "Schedules evolution cycles based on health/metrics triggers",
        "triggers": [
          "Health score drop > threshold",
          "Metric anomalies detected",
          "Periodic interval (e.g., hourly)",
          "Manual invocation via startScheduler()"
        ],
        "inputs": [
          "framework-health.generateHealthReport()",
          "metrics-engine metrics",
          "Configuration thresholds"
        ],
        "outputs": [
          "Logs evolution cycle results",
          "Triggers prompt-evolution-engine if conditions met"
        ],
        "initialization": "Started by event-integration.initializeEngines()"
      }
    ],
    "evolution_call_chain": {
      "trigger": "prompt-evolution-scheduler.startScheduler() OR manual invocation",
      "flow": [
        "1. prompt-evolution-scheduler.runSchedulerOnce()",
        "2. → getHealthAndMetrics() reads framework health + metrics",
        "3. → shouldRunEvolution() evaluates triggers",
        "4. → prompt-evolution-engine.runEvolutionCycle()",
        "5.   → prompt-analyzer.analyzePrompts() detects weaknesses",
        "6.   → prompt-analyzer.getWeaknessReport() returns findings",
        "7.   → buildImprovedPrompt{Role}(weaknesses) generates improvements",
        "8.   → prompt-version-manager.createCandidate() stores version",
        "9.   → evaluateAutoPromotion() checks promotion rules",
        "10.  → prompt-version-manager.promoteVersion() if rules pass",
        "11. ← Returns evolution report with promotions/candidates"
      ]
    },
    "integration_with_execution": {
      "load_point": "agent-executor.loadPrompt(role)",
      "strategy": "Try prompt-version-manager.getActiveVersion() first, fallback to legacy prompts/{role}.md",
      "frequency": "Every agent execution loads latest active version",
      "feedback_loop": [
        "Execution results → learning-loop-engine.analyzeExecutionResults()",
        "Lessons learned → metrics-engine.recordLesson()",
        "Metrics updated → prompt-evolution-scheduler checks triggers",
        "If triggered → new evolution cycle"
      ]
    }
  },
