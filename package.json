{
  "name": "promptagent",
  "version": "1.0.0-beta",
  "description": "Modular AI Prompt Engineering and Workflow Automation Framework",
  "main": "run.js",
  "directories": {
    "doc": "docs",
    "example": "examples"
  },
  "scripts": {
    "start": "node run.js",
    "init-project": "node scripts/init-project-v2.js",
    "generate-prompt": "node scripts/generate-prompt-v3.js",
    "validate-project": "node scripts/validate-project-v2.js",
    "evolve-prompts": "node scripts/run-prompt-evolution.js",
    "test": "node tests/phase9-prompt-evolution-test.js",
    "test:all": "node tests/phase9-prompt-evolution-test.js && node tests/phase7-integration-test.js && node tests/phase8-health-test.js && node tests/phase10-scheduler-test.js && node tests/phase95-automation-test.js && node tests/event-validation-test.js",
    "lint": "eslint --max-warnings=0",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.js\" \"!node_modules/**\" \"!archive/**\" \"!templates/**\" \"!projects/**\"",
    "format:check": "prettier --check \"**/*.js\" \"!node_modules/**\" \"!archive/**\" \"!templates/**\" \"!projects/**\""
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.5"
  }
}
