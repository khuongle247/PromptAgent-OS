{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryImportanceUpdated Event Schema",
  "description": "Schema for event emitted when the importance score of a memory record is adjusted.",
  "type": "object",
  "required": ["memoryId", "oldImportance", "newImportance", "timestamp", "schemaVersion"],
  "properties": {
    "memoryId": { "type": "string", "pattern": "^MEM-[0-9]{3,}$" },
    "oldImportance": { "type": "integer", "minimum": 1, "maximum": 5 },
    "newImportance": { "type": "integer", "minimum": 1, "maximum": 5 },
    "timestamp": { "type": "string", "format": "date-time" },
    "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+$" }
  }
}
