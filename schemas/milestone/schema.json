{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "type": "object",

  "required": ["milestones"],

  "properties": {
    "schemaVersion": {
      "type": "string"
    },

    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "tasks"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^MS-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "done"]
          }
        }
      }
    }
  }
}
