{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "type": "object",

  "required": ["tasks"],

  "properties": {
    "tasks": {
      "type": "array",

      "items": {
        "type": "object",

        "required": [
          "id",
          "title",
          "module",
          "priority",
          "dependencies",
          "definitionOfDone",
          "acceptanceCriteria"
        ],

        "properties": {
          "title": {
            "type": "string",
            "minLength": 5
          },

          "id": {
            "type": "string",
            "pattern": "^TASK-[0-9]{3,}$"
          },

          "module": {
            "type": "string",
            "minLength": 2
          },

          "priority": {
            "type": "string",
            "enum": ["P1", "P2", "P3"]
          },

          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },

          "acceptanceCriteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 5
            }
          },

          "definitionOfDone": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 5
            }
          }
        }
      }
    },

    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "tasks"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^MS-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
