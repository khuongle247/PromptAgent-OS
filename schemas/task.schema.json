{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "title": "Task Schema",

  "type": "object",

  "required": ["id", "title", "status", "priority", "acceptanceCriteria", "definitionOfDone"],

  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{3,}$"
    },

    "title": {
      "type": "string",
      "minLength": 5
    },

    "module": {
      "type": "string"
    },

    "status": {
      "type": "string",
      "enum": ["todo", "in_progress", "blocked", "review", "done", "cancelled"]
    },

    "priority": {
      "type": "string",
      "enum": ["P1", "P2", "P3"]
    },

    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },

    "estimate": {
      "type": "string"
    },

    "assignee": {
      "type": "string"
    },

    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },

    "definitionOfDone": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },

    "source": {
      "type": "string",
      "enum": ["human", "planner", "system"]
    },

    "milestoneId": {
      "type": "string"
    },

    "createdAt": {
      "type": "string"
    },

    "updatedAt": {
      "type": "string"
    }
  }
}
